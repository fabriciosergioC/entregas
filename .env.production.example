# =============================================
# VARIAVEIS DE AMBIENTE - PRODUÇÃO (Netlify)
# =============================================
# INSTRUÇÕES:
# 1. Acesse https://app.supabase.com
# 2. Selecione seu projeto
# 3. Vá em Settings → API
# 4. Copie as chaves abaixo
#
# IMPORTANTE: Se receber erro 401 "Invalid API key",
# obtenha uma nova chave no dashboard do Supabase.

# =============================================
# SUPABASE
# =============================================
# URL e chave obtidas em: https://app.supabase.com
# Substitua pelos valores do SEU projeto Supabase

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=COLE_SUA_CHAVE_ANON_AQUI

# =============================================
# OBS: Socket.IO foi removido
# =============================================
# Este projeto agora usa apenas Supabase Realtime.
# Não é necessário configurar backend separado.
# O realtime funciona nativamente através do Supabase.
