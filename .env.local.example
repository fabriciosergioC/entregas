# =============================================
# SUPABASE
# =============================================
# Obtenha em: https://app.supabase.com/project/_/settings/api

# URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Chave Anônima (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Chave Service Role (secret - apenas server-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================
# WEBSOCKET / SOCKET.IO
# =============================================

# URL do servidor WebSocket (para o frontend)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# URL alternativa da API (legacy)
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================
# SERVIDOR
# =============================================

# Porta do servidor WebSocket
PORT=3001

# Ambiente
NODE_ENV=development

# CORS - Origens permitidas (use * para desenvolvimento)
# Para produção, coloque a URL do seu frontend
CORS_ORIGIN=*

# =============================================
# DEPLOY (Opcional)
# =============================================

# URL pública do backend (quando em produção)
# NEXT_PUBLIC_SOCKET_URL=https://seu-backend.onrender.com
# NEXT_PUBLIC_API_URL=https://seu-backend.onrender.com
