{
  "name": "app-entregador",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "dev:backend": "nodemon",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "build": "next build",
    "build:server": "tsc --project tsconfig.server.json",
    "start": "next start",
    "start:backend": "npx ts-node server/index.ts",
    "start:prod": "node dist/server/index.js",
    "start:all": "concurrently \"npm run dev:backend\" \"npm run start\"",
    "lint": "next lint"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
