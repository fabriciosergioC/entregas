# Variáveis de Ambiente para Desenvolvimento
# Copie este arquivo para .env e ajuste os valores

# Porta do servidor backend
PORT=3001

# Ambiente (development ou production)
NODE_ENV=development

# CORS - Origens permitidas (use * para desenvolvimento)
# Para produção, coloque a URL do seu frontend
CORS_ORIGIN=*

# URL do backend para o frontend conectar
# Em produção: https://seu-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
